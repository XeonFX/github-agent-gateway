{
  "author": "Krystian Pawłow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XeonFX/github-agent-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/XeonFX/github-agent-gateway/issues"
  },
  "homepage": "https://github.com/XeonFX/github-agent-gateway#readme",
  "name": "github-agent-gateway",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "A safe, vendor-neutral GitHub management gateway for AI agents, hosted on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create github-agent-gateway",
    "db:migrate:local": "wrangler d1 migrations apply github-agent-gateway --local",
    "db:migrate:remote": "wrangler d1 migrations apply github-agent-gateway --remote",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "hono": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
